{
	"id": "template_calc_NDVI",
	"description": "Normalised Difference Vegetation Index (NDVI) [-1 .. +1]",
	"template": {
		"version": "1",
		"list": [
			{
				"module": "r.mapcalc",
				"id": "r.mapcalc_ndvi",
				"comment": "NDVI = ( NIR - RED ) / ( NIR + RED )",
				"inputs": [
					{
						"param": "expression",
						"value": "{{ index_name }} = float( {{ nir }} - {{ red }} ) / float( {{ nir }} + {{ red }} )"
					}
				]
			},
			{
				"module": "r.colors",
				"id": "r.colors_ndvi",
				"inputs": [
					{
						"param": "map",
						"value": "{{ index_name }}"
					},
					{
						"param": "color",
						"value": "ndvi"
					}
				]
			},
			{
				"id": "exporter_1",
				"module": "exporter",
				"outputs": [
					{
						"export": {
							"type": "raster",
							"format": "GTiff"
						},
						"param": "map",
						"value": "{{ index_name }}"
					}
				]
			}
		]
	}
}