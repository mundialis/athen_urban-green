{
	"id": "template_S2_processing",
    "description": "Main processing template that loops through S2 IDs, downloads and imports the scenes, applies masks, calculates indices, creates STAC items, and cleans up intermediate data.",
	"template": {
        "list": [
			{% for i in iteration %}
		{
			"id": "template_S2_download_import_1",
			"module": "template_S2_download_import",
			"inputs": [
				{
					"param": "S2_ID",
					"value": "{{ i.s2_id }}"
				},
				{
					"param": "download_dir",
					"value": "/src/download_dir/s2"
				}
			]
		},
		{
			"id": "python_1",
			"exe": "python",
			"params": ["/src/processing/scripts/remove_data.py", "/src/download_dir"]
		},
		{
			"id": "python_2",
			"exe": "python",
			"params": [
				"/src/processing/scripts/rename_bands.py"
			]
		},		
		{
			"id": "r.mask_1",
			"module": "r.mask",
			"inputs": [
				{
					"param": "raster",
					"value": "MSK"
				}
			],
			"flags": "i"
		},
		{
			"id": "python_3",
			"exe": "python",
			"params": ["/src/processing/scripts/create_export_subfolders.py", "/src/export_dir/{{ i.year }}/{{ tile_id }}"]
		},
		{
			"id": "template_calc_NDVI_1",
			"module": "template_calc_NDVI",
			"inputs": [
				{
					"param": "red",
					"value": "B04"
				},
				{
					"param": "nir",
					"value": "B08"
				},
				{
					"param": "index_name",
					"value": "ndvi_{{ i.s2_id }}"
				},
				{
					"param": "export_dir",
					"value": "/src/export_dir/{{ i.year }}/{{ tile_id }}"
				}
			]
		},
		{
			"id": "template_calc_NDWI_1",
			"module": "template_calc_NDWI",
			"inputs": [
				{
					"param": "swir",
					"value": "B11"
				},
				{
					"param": "nir",
					"value": "B08"
				},
				{
					"param": "index_name",
					"value": "ndwi_{{ i.s2_id }}"
				},
				{
					"param": "export_dir",
					"value": "/src/export_dir/{{ i.year }}/{{ tile_id }}"
				}
			]
		},
		{
			"id": "i_create_stac_1",
			"module": "i.create.stac",
			"inputs": [
				{
					"param": "asset_paths",
					"value": "/src/export_dir/{{ i.year }}/{{ tile_id }}/ndvi_{{ i.s2_id }}.tif,/src/export_dir/{{ i.year }}/{{ tile_id }}/ndvi_{{ i.s2_id }}_categorized.tif,/src/export_dir/{{ i.year }}/{{ tile_id }}/ndwi_{{ i.s2_id }}.tif,/src/export_dir/{{ i.year }}/{{ tile_id }}/ndwi_{{ i.s2_id }}_categorized.tif"
				},
				{
					"param": "asset_names",
					"value": "{{ asset_names }}"
				},
				{
					"param": "s2_id",
					"value": "{{ i.s2_id }}"
				},
				{
					"param": "stac_id_prefix",
					"value": "{{ stac_item_id_prefix }}"
				},
				{
					"param": "stac_title",
					"value": "{{ stac_item_title }}"
				},
				{
					"param": "stac_description",
					"value": "{{ stac_item_description }}"
				},
				{
					"param": "stac_catalog",
					"value": "{{ stac_catalog_url }}"
				},
				{
					"param": "stac_collection",
					"value": "{{ stac_collection }}"
				}
			]
		},
		{
			"id": "r.mask_2",
			"module": "r.mask",
			"inputs": [
				{
					"param": "raster",
					"value": "MSK"
				}
			],
			"flags": "r"
		}{{ "," if not loop.last }}
            {% endfor %}
        ],
        "version": "1"
    }
}