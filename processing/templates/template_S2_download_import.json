{
	"id": "template_S2_download_import",
	"description": "Downloads and imports S2 scene using scene ID.",
	"template": {
		"version": "1",
		"list": [
			{
			"id": "g.region_1",
			"module": "g.region",
			"inputs": [
				{
					"param": "vector",
					"value": "aoi@vector_data"
				},
				{
					"param": "res",
					"value": "10"
				}
			],
			"flags": "g"
			},
			{
				"module": "i.s2_id.download",
				"id": "i.s2_id.download_1",
				"inputs": [
					{
						"param": "s2_id",
						"value": "{{ S2_ID }}"
					},
					{
						"param": "download_dir",
						"value": "{{ download_dir }}"
					}
				]
			},
			{
				"module": "i.sentinel.import",
				"id": "i.sentinel.import_1",
				"inputs": [
					{
						"param": "input",
						"value": "{{ download_dir }}"
					},
					{
						"param": "pattern",
						"value": "B(02_1|03_1|04_1|08_1|8A_2|11_2|12_2)0m"
					},
					{
						"param": "cloud_probability_threshold",
						"value": "65"
					},
					{
						"param": "cloud_output",
						"value": "raster"
					},
					{
						"param": "extent",
						"value": "region"
					},
					{
						"param": "memory",
						"value": "3000"
					}
				],
				"flags": "cr"
			}
		]
	}
}