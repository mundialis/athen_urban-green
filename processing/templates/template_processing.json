{
	"id": "template_processing",
    "description": "processing template",
	"template": {
        "list": [
			{
			"id": "g.region_1",
			"module": "g.region",
			"inputs": [
				{
					"param": "vector",
					"value": "aoi@vector_data"
				},
				{
					"param": "res",
					"value": "10"
				}
			],
			"flags": "g"
		},
			{% for i in iteration %}
		{
			"id": "template_S2_download_import_1",
			"module": "template_S2_download_import",
			"inputs": [
				{
					"param": "S2_ID",
					"value": "{{ i }}"
				},
				{
					"param": "download_dir",
					"value": "/home/data/s2"
				}
			]
		},
		{
			"id": "python_1",
			"exe": "python",
			"params": ["/src/processing/scripts/remove_data.py", "/home/data"]
		},
		{
			"id": "python_2",
			"exe": "python",
			"params": [
				"/src/processing/scripts/rename_bands.py"
			]
		},		
		{
			"id": "r.mask_1",
			"module": "r.mask",
			"inputs": [
				{
					"param": "raster",
					"value": "MSK"
				}
			],
			"flags": "i"
		},
		{
			"id": "template_calc_NDVI_1",
			"module": "template_calc_NDVI",
			"inputs": [
				{
					"param": "red",
					"value": "B04"
				},
				{
					"param": "nir",
					"value": "B08"
				},
				{
					"param": "index_name",
					"value": "ndvi_{{ i }}"
				},
				{
					"param": "export_dir",
					"value": "/src/data_tmp"
				}
			]
		},
		{
			"id": "template_calc_NDWI_1",
			"module": "template_calc_NDWI",
			"inputs": [
				{
					"param": "swir",
					"value": "B11"
				},
				{
					"param": "nir",
					"value": "B08"
				},
				{
					"param": "index_name",
					"value": "ndwi_{{ i }}"
				},
				{
					"param": "export_dir",
					"value": "/src/data_tmp"
				}
			]
		},
		{
			"id": "i_create_stac_1",
			"module": "i.create.stac",
			"inputs": [
				{
					"param": "asset_paths",
					"value": "/src/data_tmp/ndvi_{{ i }}.tif,/src/data_tmp/ndvi_{{ i }}_categorized.tif,/src/data_tmp/ndwi_{{ i }}.tif,/src/data_tmp/ndwi_{{ i }}_categorized.tif"
				},
				{
					"param": "asset_names",
					"value": "{{ asset_names }}"
				},
				{
					"param": "s2_id",
					"value": "{{ i }}"
				},
				{
					"param": "stac_id_prefix",
					"value": "{{ stac_item_id_prefix }}"
				},
				{
					"param": "stac_title",
					"value": "{{ stac_item_title }}"
				},
				{
					"param": "stac_description",
					"value": "{{ stac_item_description }}"
				},
				{
					"param": "stac_catalog",
					"value": "{{ stac_catalog_url }}"
				},
				{
					"param": "stac_collection",
					"value": "{{ stac_collection }}"
				}
			]
		},
		{
			"id": "r.mask_2",
			"module": "r.mask",
			"inputs": [
				{
					"param": "raster",
					"value": "MSK"
				}
			],
			"flags": "r"
		}{{ "," if not loop.last }}
            {% endfor %}
        ],
        "version": "1"
    }
}